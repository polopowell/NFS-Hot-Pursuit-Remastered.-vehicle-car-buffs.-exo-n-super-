//code from here to '[DISABLE]' will be used to enable the cheat
{$Lua}

function CheckAndAdjust(sender)
  local IG_HUE=readFloat("[NFS11Remastered.exe+01296B80]+3E0")
  local IG_Saturation=readFloat("[NFS11Remastered.exe+01296B80]+3E4")
  local IG_Brightness=readFloat("[NFS11Remastered.exe+01296B80]+3E8")
  --split
  if (IG_HUE &gt; 1 ) then
  writeFloat("[NFS11Remastered.exe+01296B80]+3E0", 0)
  else
  writeFloat("[NFS11Remastered.exe+01296B80]+3E0", IG_HUE+0.01)
  end
  --split
end

t=createTimer(nil)
timer_setInterval(t, 1)
timer_onTimer(t, CheckAndAdjust)
timer_setEnabled(t, true)

 [DISABLE]
//code from here till the end of the code will be used to disable the cheat

{$Lua}
t.destroy();
t=nil
</AssemblerScript>
                </CheatEntry>
                <CheatEntry>
                  <ID>6</ID>
                  <Description>"RGB [Ugly script]"</Description>
                  <Color>F385D5</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$LUA}
if syntaxcheck then return end
function randomVal(timer)
  local addr = getAddressSafe("randomValues")
  hue = hue or 0
  if addr then
    hue = hue - 0.003
    if hue &lt; 0.001 then
      hue = 1
    end
    writeFloat(addr, hue)
    writeFloat(addr+4, 1)
    writeFloat(addr+8, 1)
  end
end

function start_process()
  randomValueTimer = randomValueTimer or createTimer()
  randomValueTimer.Interval = 1 -- 200 ms enough?
  randomValueTimer.OnTimer = function()
    randomVal()
  end
end

function on_close()
  randomValueTimer.Interval = 0
  randomValueTimer.destroy()
  randomValueTimer = nil
end
